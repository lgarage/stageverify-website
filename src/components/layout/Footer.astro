---
import Logo from "../ui/Logo.astro";
import { navLinks, site } from "../../data/site";
---

<footer class="border-t border-white/10 bg-navy-dark py-12 text-white">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-10 md:grid-cols-2 md:gap-8 lg:grid-cols-3">
      <div class="lg:col-span-2">
        <Logo size="footer" />
        <p class="mt-4 max-w-md text-sm leading-relaxed text-white/70">
          {site.footerDescription}
        </p>
      </div>

      <div>
        <p class="text-sm font-semibold uppercase tracking-wider text-sv-cyan">Navigate</p>
        <ul class="mt-4 space-y-2">
          {
            navLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-white/70 transition-colors hover:text-white"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div class="mt-10 border-t border-white/10 pt-6">
      <p class="text-xs text-white/50">
        &copy; {new Date().getFullYear()} StageVerify. All rights reserved.
      </p>
    </div>
  </div>
</footer>

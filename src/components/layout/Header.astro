---
import Logo from "../ui/Logo.astro";
import Button from "../ui/Button.astro";
import { navLinks } from "../../data/site";
---

<header
  class="fixed inset-x-0 top-0 z-50 border-b border-white/10 bg-navy/90 backdrop-blur-md"
>
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-3 px-4 py-3 sm:gap-4 sm:px-6 sm:py-4 lg:px-8">
    <Logo size="header" />

    <nav class="hidden items-center gap-8 md:flex" aria-label="Main navigation">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm font-medium text-white/80 transition-colors hover:text-white"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <Button href="#demo" variant="primary" size="sm" class="hidden sm:inline-flex">
        Request Demo
      </Button>

      <details class="relative md:hidden">
        <summary
          class="flex h-10 w-10 cursor-pointer list-none items-center justify-center rounded-lg border border-white/20 text-white [&::-webkit-details-marker]:hidden"
          aria-label="Open menu"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </summary>
        <div
          class="absolute right-0 mt-2 w-56 rounded-xl border border-white/10 bg-navy-light p-3 shadow-xl"
        >
          <nav class="flex flex-col gap-1" aria-label="Mobile navigation">
            {
              navLinks.map((link) => (
                <a
                  href={link.href}
                  class="rounded-lg px-3 py-2 text-sm font-medium text-white/90 hover:bg-white/10"
                >
                  {link.label}
                </a>
              ))
            }
            <a
              href="#demo"
              class="mt-2 rounded-lg bg-sv-blue px-3 py-2 text-center text-sm font-semibold text-white"
            >
              Request Demo
            </a>
          </nav>
        </div>
      </details>
    </div>
  </div>
  <script is:inline>
    document.querySelectorAll("header details nav a").forEach(function (link) {
      link.addEventListener("click", function () {
        var menu = link.closest("details");
        if (menu) menu.removeAttribute("open");
      });
    });
  </script>
</header>

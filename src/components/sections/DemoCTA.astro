---
import SectionShell from "../ui/SectionShell.astro";
import SectionHeader from "../ui/SectionHeader.astro";
import Button from "../ui/Button.astro";
import { sectionCopy } from "../../data/site";
---

<SectionShell id="demo" variant="navy" containerClass="text-center">
  <div class="mx-auto max-w-2xl">
    <SectionHeader
      eyebrow={sectionCopy.demo.eyebrow}
      title="Put your material handoff on a silver platter."
      description={sectionCopy.demo.intro}
      dark
    />

    <div class="mt-10 flex flex-col items-center gap-3">
      <Button href="#demo" variant="primary" size="lg" class="min-w-[220px] shadow-lg shadow-sv-blue/25">
        Request Demo
      </Button>
      <p class="text-xs text-white/50">{sectionCopy.demo.reassurance}</p>
    </div>
  </div>
</SectionShell>

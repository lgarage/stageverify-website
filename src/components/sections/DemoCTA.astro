---
import SectionShell from "../ui/SectionShell.astro";
import Button from "../ui/Button.astro";
---

<SectionShell id="demo" variant="navy" containerClass="text-center">
  <div class="mx-auto max-w-2xl">
    <h2 class="text-2xl font-bold tracking-tight text-white sm:text-3xl md:text-4xl">
      Put your material handoff on a silver platter.
    </h2>
    <p class="mt-5 text-base leading-relaxed text-white/80 sm:text-lg">
      Give operations a clear view of what arrived, where it was staged, whether it is complete,
      and when it was picked up.
    </p>
    <div class="mt-8">
      <Button href="#demo" variant="primary" size="lg" class="min-w-[200px]">
        Request Demo
      </Button>
    </div>
  </div>
</SectionShell>

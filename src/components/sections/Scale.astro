---
import SectionShell from "../ui/SectionShell.astro";
import SectionHeader from "../ui/SectionHeader.astro";
import { scaleStages, sectionCopy } from "../../data/site";
---

<SectionShell id="scale" variant="navy-gradient">
  <div class="grid items-start gap-14 lg:grid-cols-2 lg:gap-16">
    <div>
      <SectionHeader
        eyebrow={sectionCopy.scale.eyebrow}
        title="Start with one shop. Expand to every branch."
        description={sectionCopy.scale.intro}
        dark
        align="left"
        class="max-w-xl"
      />
      <p class="mt-6 text-sm leading-relaxed text-white/60">
        Grounded in contractor shops and staging bays — not massive automated warehouses.
      </p>
    </div>

    <div class="space-y-3" aria-label="Growth path">
      {
        scaleStages.map((stage, index) => (
          <div
            class:list={[
              "flex gap-4 rounded-2xl border border-white/10 p-5 transition-colors",
              index === scaleStages.length - 1
                ? "bg-sv-blue/15 ring-1 ring-sv-cyan/25"
                : "bg-white/[0.04] hover:bg-white/[0.06]",
            ]}
          >
            <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-sv-cyan/15 text-sm font-bold text-sv-cyan">
              {index + 1}
            </span>
            <div class="min-w-0 flex-1">
              <p class="font-semibold text-white">{stage.title}</p>
              <p class="mt-1 text-sm leading-relaxed text-white/65">{stage.description}</p>
              <div class="mt-3 flex gap-1" aria-hidden="true">
                {
                  Array.from({ length: index + 1 }).map(() => (
                    <span class="h-1.5 flex-1 rounded-full bg-sv-cyan/35" />
                  ))
                }
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</SectionShell>

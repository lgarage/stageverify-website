---
import SectionShell from "../ui/SectionShell.astro";
import { scaleStages } from "../../data/site";
---

<SectionShell id="scale" variant="navy-gradient">
  <div class="grid items-center gap-12 lg:grid-cols-2">
    <div>
      <h2 class="text-2xl font-bold tracking-tight text-white sm:text-3xl md:text-4xl">
        Start with one shop. Expand to every branch.
      </h2>
      <p class="mt-5 text-base leading-relaxed text-white/80 sm:text-lg">
        StageVerify is designed to begin with a simple shop staging workflow and grow into a
        larger contractor material-control system across multiple locations.
      </p>
    </div>

    <div class="relative" aria-hidden="true">
      <div class="space-y-3">
        {
          scaleStages.map((stage, index) => (
            <div
              class:list={[
                "flex items-center gap-4 rounded-xl border border-white/10 p-4 transition-all",
                index === scaleStages.length - 1
                  ? "bg-sv-blue/20 ring-1 ring-sv-cyan/30"
                  : "bg-white/5",
              ]}
            >
              <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-sv-cyan/20 text-sm font-bold text-sv-cyan">
                {index + 1}
              </span>
              <div class="min-w-0 flex-1">
                <p class="font-semibold text-white">{stage}</p>
                <div class="mt-2 flex gap-1">
                  {
                    Array.from({ length: index + 1 }).map(() => (
                      <span class="h-2 flex-1 rounded-full bg-sv-cyan/40" />
                    ))
                  }
                </div>
              </div>
              {
                index < scaleStages.length - 1 && (
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-white/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                )
              }
            </div>
          ))
        }
      </div>
      <p class="mt-4 text-center text-xs text-white/50">
        Grounded in contractor shops — not massive automated warehouses.
      </p>
    </div>
  </div>
</SectionShell>

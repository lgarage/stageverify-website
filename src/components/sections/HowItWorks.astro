---
import SectionShell from "../ui/SectionShell.astro";
import SectionHeader from "../ui/SectionHeader.astro";
import { howItWorksSteps, sectionCopy } from "../../data/site";
---

<SectionShell id="how-it-works" variant="steel">
  <SectionHeader
    eyebrow={sectionCopy.howItWorks.eyebrow}
    title="One clear trail from delivery to pickup."
    description={sectionCopy.howItWorks.intro}
  />

  <ol class="mt-14 grid gap-5 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5">
    {
      howItWorksSteps.map((item) => (
        <li class="group relative flex flex-col rounded-2xl border border-sv-border-light bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
          <span class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-full bg-sv-blue text-sm font-bold text-white shadow-sm">
            {item.step}
          </span>
          <h3 class="text-base font-semibold text-navy">{item.title}</h3>
          <p class="mt-2 flex-1 text-sm leading-relaxed text-gray-text">{item.description}</p>
        </li>
      ))
    }
  </ol>
</SectionShell>

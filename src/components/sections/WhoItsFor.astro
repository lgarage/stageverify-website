---
import SectionShell from "../ui/SectionShell.astro";
import Card from "../ui/Card.astro";
import { industries } from "../../data/site";
---

<SectionShell id="who-its-for" variant="white">
  <div class="mx-auto max-w-3xl text-center">
    <h2 class="text-2xl font-bold tracking-tight text-navy sm:text-3xl md:text-4xl">
      Built for trade contractors moving job materials through a shop.
    </h2>
  </div>

  <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    {
      industries.map((industry) => (
        <Card class="h-full text-center">
          <div class="flex flex-col items-center">
            <span
              class="mb-3 inline-flex h-11 w-11 items-center justify-center rounded-xl bg-sv-blue/10 text-sv-blue"
              aria-hidden="true"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a1 1 0 00-1.022-.083M5 12h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7" />
              </svg>
            </span>
            <h3 class="text-sm font-semibold text-navy sm:text-base">{industry}</h3>
          </div>
        </Card>
      ))
    }
  </div>
</SectionShell>

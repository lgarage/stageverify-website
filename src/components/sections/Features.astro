---
import SectionShell from "../ui/SectionShell.astro";
import SectionHeader from "../ui/SectionHeader.astro";
import { features, sectionCopy } from "../../data/site";
---

<SectionShell id="features" variant="navy">
  <SectionHeader
    eyebrow={sectionCopy.features.eyebrow}
    title="Shop staging control without a full warehouse system."
    dark
  />

  <ul class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-2 xl:grid-cols-4">
    {
      features.map((feature) => (
        <li class="flex h-full flex-col rounded-2xl border border-white/10 bg-white/[0.04] p-6 backdrop-blur-sm transition-colors hover:border-white/20 hover:bg-white/[0.07]">
          <span
            class="mb-4 inline-flex h-8 w-8 items-center justify-center rounded-lg bg-sv-cyan/15 text-sv-cyan"
            aria-hidden="true"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </span>
          <h3 class="text-sm font-semibold leading-snug text-white sm:text-base">{feature.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-white/65">{feature.description}</p>
        </li>
      ))
    }
  </ul>
</SectionShell>

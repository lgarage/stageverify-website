---
import Button from "../ui/Button.astro";
import HeroMockup from "../ui/HeroMockup.astro";
import { site } from "../../data/site";
---

<section
  class="relative overflow-hidden bg-navy pt-32 pb-16 md:pt-36 md:pb-24"
  aria-labelledby="hero-heading"
>
  <div
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--sv-blue)_0%,_transparent_50%)] opacity-20"
    aria-hidden="true"
  ></div>
  <div
    class="pointer-events-none absolute -left-32 top-1/2 h-96 w-96 rounded-full bg-sv-cyan/10 blur-3xl"
    aria-hidden="true"
  ></div>

  <div class="relative mx-auto grid max-w-6xl items-center gap-12 px-4 sm:px-6 lg:grid-cols-2 lg:gap-16 lg:px-8">
    <div class="max-w-xl">
      <p class="mb-4 text-sm font-semibold uppercase tracking-wider text-sv-cyan">
        Material staging system for trade contractors
      </p>
      <h1 id="hero-heading" class="text-3xl font-bold leading-tight tracking-tight text-white sm:text-4xl lg:text-5xl">
        {site.headline}
      </h1>
      <p class="mt-5 text-base leading-relaxed text-white/80 sm:text-lg">
        {site.description}
      </p>
      <p class="mt-4 text-sm font-medium leading-relaxed text-sv-cyan/90 sm:text-base">
        {site.positioning}
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <Button href="#how-it-works" variant="primary" size="lg">
          See How It Works
        </Button>
        <Button href="#demo" variant="secondary" size="lg">
          Request Demo
        </Button>
      </div>
    </div>

    <div class="lg:justify-self-end">
      <HeroMockup />
    </div>
  </div>
</section>

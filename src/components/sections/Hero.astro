---
import Button from "../ui/Button.astro";
import HeroMockup from "../ui/HeroMockup.astro";
import { site } from "../../data/site";
---

<section
  class="relative overflow-hidden bg-navy pt-28 pb-16 sm:pt-32 sm:pb-20 md:pt-36 md:pb-28"
  aria-labelledby="hero-heading"
>
  <div
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--sv-blue)_0%,_transparent_55%)] opacity-25"
    aria-hidden="true"
  ></div>
  <div
    class="pointer-events-none absolute -left-40 top-1/3 h-[28rem] w-[28rem] rounded-full bg-sv-cyan/10 blur-3xl"
    aria-hidden="true"
  ></div>
  <div
    class="pointer-events-none absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"
    aria-hidden="true"
  ></div>

  <div class="relative mx-auto grid max-w-6xl items-center gap-12 px-4 sm:px-6 lg:grid-cols-2 lg:gap-20 lg:px-8">
    <div class="max-w-xl">
      <p class="mb-4 inline-flex items-center rounded-full border border-white/15 bg-white/5 px-3 py-1 text-xs font-semibold uppercase tracking-widest text-sv-cyan">
        Material staging for trade contractors
      </p>
      <h1 id="hero-heading" class="text-3xl font-bold leading-[1.12] tracking-tight text-white sm:text-4xl lg:text-[2.75rem]">
        {site.headline}
      </h1>
      <p class="mt-5 text-base leading-relaxed text-white/80 sm:mt-6 sm:text-lg">
        {site.description}
      </p>
      <p class="mt-4 border-l-2 border-sv-cyan/50 pl-4 text-sm font-medium leading-relaxed text-white/90 sm:text-base">
        {site.positioning}
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:mt-9 sm:flex-row sm:flex-wrap">
        <Button href="#how-it-works" variant="primary" size="lg" class="w-full shadow-lg shadow-sv-blue/20 sm:w-auto">
          See How It Works
        </Button>
        <Button href="#demo" variant="secondary" size="lg" class="w-full sm:w-auto">
          Request Demo
        </Button>
      </div>
    </div>

    <div class="mx-auto w-full max-w-[19rem] sm:max-w-md lg:mx-0 lg:max-w-lg lg:justify-self-end">
      <HeroMockup />
    </div>
  </div>
</section>

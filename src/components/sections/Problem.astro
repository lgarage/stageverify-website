---
import SectionShell from "../ui/SectionShell.astro";
import SectionHeader from "../ui/SectionHeader.astro";
import Card from "../ui/Card.astro";
import { problemCards, sectionCopy, problemCallout } from "../../data/site";
---

<SectionShell id="problem" variant="white">
  <SectionHeader
    eyebrow={sectionCopy.problem.eyebrow}
    title={sectionCopy.problem.title}
    description={sectionCopy.problem.intro}
  />

  <div class="mt-12 grid gap-5 sm:grid-cols-2 md:mt-14 lg:grid-cols-4">
    {
      problemCards.map((problem) => (
        <Card class="h-full border-sv-border-light/80">
          <div class="flex h-full flex-col">
            <span
              class="mb-4 inline-flex h-9 w-9 items-center justify-center rounded-lg bg-red-50 text-red-500"
              aria-hidden="true"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </span>
            <p class="text-sm font-semibold leading-snug text-navy sm:text-base">{problem.title}</p>
          </div>
        </Card>
      ))
    }
  </div>

  <p class="mx-auto mt-12 max-w-3xl rounded-2xl border border-sv-border-light bg-steel/60 px-6 py-5 text-center text-base leading-relaxed text-gray-text sm:text-lg md:mt-14">
    {problemCallout.lead}
    <span class="font-semibold text-navy">{problemCallout.emphasis}</span>
  </p>
</SectionShell>

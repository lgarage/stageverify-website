---
import { publicAsset } from "../../utils/publicAsset";

interface Props {
  class?: string;
  size?: "header" | "footer";
}

const { class: className = "", size = "header" } = Astro.props;

const logoSrc = publicAsset("images/svlogo_full.png");

const sizes = {
  header: "h-9 max-w-[10.5rem] w-auto sm:h-11 sm:max-w-none md:h-12",
  footer: "h-9 w-auto sm:h-10",
};
---

<a href={import.meta.env.BASE_URL} class:list={["inline-flex shrink-0 items-center", className]} aria-label="StageVerify home">
  <img
    src={logoSrc}
    alt="StageVerify"
    class:list={[sizes[size], "object-contain"]}
    width="280"
    height="70"
  />
</a>

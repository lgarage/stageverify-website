---
interface Props {
  class?: string;
  size?: "header" | "footer";
}

const { class: className = "", size = "header" } = Astro.props;

const logoSrc = `${import.meta.env.BASE_URL}images/svlogo_full.png`;

const sizes = {
  header: "h-10 w-auto sm:h-11 md:h-12",
  footer: "h-9 w-auto sm:h-10",
};
---

<a href="#" class:list={["inline-flex shrink-0 items-center", className]} aria-label="StageVerify home">
  <img
    src={logoSrc}
    alt="StageVerify"
    class:list={[sizes[size], "object-contain"]}
    width="280"
    height="70"
  />
</a>

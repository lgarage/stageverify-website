---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  dark?: boolean;
  align?: "center" | "left";
  class?: string;
}

const {
  eyebrow,
  title,
  description,
  dark = false,
  align = "center",
  class: className = "",
} = Astro.props;

const titleClass = dark ? "text-white" : "text-navy";
const descClass = dark ? "text-white/70" : "text-gray-text";
const eyebrowClass = dark ? "text-sv-cyan" : "text-sv-blue";
const alignClass = align === "left" ? "text-left" : "text-center mx-auto max-w-3xl";
const descAlignClass = align === "left" ? "max-w-xl" : "mx-auto max-w-2xl";
---

<div class:list={[alignClass, className]}>
  {
    eyebrow && (
      <p class:list={["mb-3 text-sm font-bold uppercase tracking-wide sm:text-base", eyebrowClass]}>
        {eyebrow}
      </p>
    )
  }
  <h2
    class:list={[
      "text-2xl font-bold leading-[1.15] tracking-tight sm:text-3xl md:text-4xl",
      titleClass,
    ]}
  >
    {title}
  </h2>
  {
    description && (
      <p class:list={["mt-4 text-base leading-relaxed sm:text-lg", descAlignClass, descClass]}>
        {description}
      </p>
    )
  }
</div>
